# Exclude stale CodeQL database copies and other generated artifacts

# from clangd indexing to prevent false redefinition errors

Index:
  Exclude:
    - .aidex
    - .cache
    - .claude
    - .cocoindex_code
    - .codegraph
    - .continue
    - .playwright-mcp
    - .serena
    - .venv-codegraph
    - .vs
    - .vscode
    - config
    - doc
    - evidence
    - graphify-out
    - manual
    - sampledata
    - steering
    - storage
    - tools
    - .musubi
    - storage/codeql

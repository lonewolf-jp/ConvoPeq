{
    "configurations": [
        {
            "name": "Windows x64 (MSVC)",
            "configurationProvider": "ms-vscode.cmake-tools",
            "compilerPath": "",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "windows-msvc-x64",
            "compilerArgs": [
                "/utf-8",
                "/std:c++20",
                "/EHsc",
                "/permissive-"
            ],
            "defines": [
                "_UNICODE",
                "UNICODE",
                "NOMINMAX",
                "_CRT_SECURE_NO_WARNINGS",
                "JUCE_GLOBAL_MODULE_SETTINGS_INCLUDED=1",
                "JUCE_STANDALONE_APPLICATION=1"
            ],
            "includePath": [
                "${workspaceFolder}/src",
                "${workspaceFolder}/src/audioengine",
                "${workspaceFolder}/src/convolver",
                "${workspaceFolder}/src/core",
                "${workspaceFolder}/src/eqprocessor",
                "${workspaceFolder}/JUCE/modules",
                "${workspaceFolder}/r8brain-free-src"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/src",
                    "${workspaceFolder}/JUCE/modules"
                ],
                "limitSymbolsToIncludedHeaders": true,
                "databaseFilename": "${workspaceFolder}/.vscode/.browse.cache"
            },
            "forcedInclude": [],
            "mergeConfigurations": false
        }
    ],
    "version": 4
}

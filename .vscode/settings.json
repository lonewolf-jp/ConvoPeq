{
    "cmake.generator": "Ninja Multi-Config",
    "cmake.setBuildTypeOnMultiConfig": true,
    "cmake.options.statusBarVisibility": "visible",
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureArgs": [
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
    ],
    "files.associations": {
        "*.h": "cpp",
        "*.cpp": "cpp"
    },
    "files.encoding": "utf8",
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
    "C_Cpp.default.compilerPath": "cl.exe",
    "C_Cpp.default.intelliSenseMode": "windows-msvc-x64",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true,
    "files.readonlyInclude": {
        "JUCE/**": true,
        "r8brain-free-src/**": true
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.codeAnalysis.clangTidy.path": "C:/Program Files/Microsoft Visual Studio/18/Enterprise/VC/Tools/Llvm/x64/bin/clang-tidy.exe",
    "C_Cpp.codeAnalysis.clangTidy.useBuildPath": true,
    "C_Cpp.codeAnalysis.clangTidy.headerFilter": ".*/src/.*",
    "editor.formatOnSave": true,
    "C_Cpp.clang_format_path": "C:/Program Files/Microsoft Visual Studio/18/Enterprise/VC/Tools/Llvm/x64/bin/clang-format.exe",
    "C_Cpp.clang_format_style": "file",
    "C_Cpp.codeAnalysis.clangTidy.checks.enabled": [
        "*"
    ],
    // MCPサーバーの自動起動を有効化
    "github.copilot.chat.mcp.enabled": true,
    // AIによるファイルの自動読み込み範囲を最適化
    "github.copilot.editor.enableCodeActions": true,
    // Serenaが作成したインデックス（Memories）を優先的に参照させる
    "github.copilot.chat.search.semanticScrolling": true,
    "github.copilot.chat.mcp.allowedServers": [
        "serena"
    ],
    "github.copilot.selectedMode": "agent"
}